@rendermode InteractiveServer
@inherits LayoutComponentBase
@inject AuthenticationService AuthService
@inject RolePermissionService PermissionService
@inject NavigationManager Nav
@implements IDisposable

<div class="page">
    @if (AuthService.IsAuthenticated())
    {
        <div class="sidebar">
            <NavMenu />
        </div>
    }

    <main>
        <div class="top-row px-4">
            <span>Frontend Blazor — API GenericaCsharp</span>
        </div>

        <article class="content px-4 @GetPermissionCssClass()">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An error has occurred.
    <a href="." class="reload">Reload</a>
</div>

@code {
    protected override void OnInitialized()
    {
        AuthService.OnAuthenticationChanged += StateHasChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    public void Dispose()
    {
        AuthService.OnAuthenticationChanged -= StateHasChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    private string GetPermissionCssClass()
    {
        var path = "/" + Nav.ToBaseRelativePath(Nav.Uri).Trim('/').ToLowerInvariant();
        var permisos = PermissionService.GetUiPermissionsForPath(path);

        var clases = new List<string>();

        if (!permisos.CanCreate)
        {
            clases.Add("perm-no-create");
        }

        if (!permisos.CanEdit)
        {
            clases.Add("perm-no-edit");
        }

        if (!permisos.CanDelete)
        {
            clases.Add("perm-no-delete");
        }

        if (!permisos.CanSave)
        {
            clases.Add("perm-no-save");
        }

        if (!permisos.CanManageIntermediates)
        {
            clases.Add("perm-no-intermediate");
        }

        return string.Join(" ", clases);
    }
}
