@page "/apoyos-profesoral"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <h3>Apoyo Profesoral</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Apoyo</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Apoyo" : "Nuevo Apoyo")</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Estudio</label>
                        <select class="form-select" @bind="campoEstudios" disabled="@editando">
                            <option value="">-- Seleccione --</option>
                            @foreach (var e in estudios)
                            {
                                <option value="@e["id"]">@e["titulo"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Con Apoyo</label>
                        <input class="form-check-input" type="checkbox" @bind="campoConApoyo" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Institución</label>
                        <input class="form-control" @bind="campoInstitucion" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Tipo</label>
                        <input class="form-control" @bind="campoTipo" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Estudio</th><th>Con Apoyo</th><th>Institución</th><th>Tipo</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerNombre(estudios, reg.GetValueOrDefault("estudios"), "id", "titulo")</td>
                        <td>@reg.GetValueOrDefault("con_apoyo")</td>
                        <td>@reg.GetValueOrDefault("institucion")</td>
                        <td>@reg.GetValueOrDefault("tipo")</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en apoyo_profesoral.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> estudios = new();
    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false;
    private string mensaje = string.Empty, campoInstitucion = string.Empty, campoTipo = string.Empty;
    private int? campoEstudios = null;
    private bool campoConApoyo = false;

    protected override async Task OnInitializedAsync()
    {
        estudios = await Api.ListarAsync("estudios_realizados");
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("apoyo_profesoral");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoEstudios = null; campoConApoyo = false;
        campoInstitucion = string.Empty; campoTipo = string.Empty;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        if (int.TryParse(reg.GetValueOrDefault("estudios")?.ToString(), out int e)) campoEstudios = e;
        campoConApoyo = reg.GetValueOrDefault("con_apoyo") as bool? ?? false;
        campoInstitucion = reg.GetValueOrDefault("institucion")?.ToString() ?? "";
        campoTipo = reg.GetValueOrDefault("tipo")?.ToString() ?? "";
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["estudios"] = campoEstudios, ["con_apoyo"] = campoConApoyo,
            ["institucion"] = campoInstitucion, ["tipo"] = campoTipo
        };
        (bool exito, string mensaje) resultado;
        if (editando)
            resultado = await Api.ActualizarAsync("apoyo_profesoral", "estudios", campoEstudios.ToString()!, datos);
        else
            resultado = await Api.CrearAsync("apoyo_profesoral", datos);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        var resultado = await Api.EliminarAsync("apoyo_profesoral", "estudios", reg.GetValueOrDefault("estudios")?.ToString() ?? "");
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }

    private string ObtenerNombre(List<Dictionary<string, object?>> lista, object? id, string campoId, string campoNombre)
    {
        if (id == null) return "";
        var item = lista.FirstOrDefault(x => x[campoId]?.ToString() == id.ToString());
        return item?[campoNombre]?.ToString() ?? id.ToString() ?? "";
    }
}