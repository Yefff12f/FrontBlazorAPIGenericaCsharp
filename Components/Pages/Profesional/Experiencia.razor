@page "/experiecia"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <h3>Experiencia</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Experiencia</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Experiencia" : "Nueva Experiencia")</div>
            <div class="card-body">
                <div class="row">
                    @if (editando)
                    {
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Id</label>
                            <input class="form-control" @bind="campoId" disabled />
                        </div>
                    }
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Nombre Cargo</label>
                        <input class="form-control" @bind="campoNombreCargo" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Institución</label>
                        <input class="form-control" @bind="campoInstitucion" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="campoNombre" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Tipo</label>
                        <input class="form-control" @bind="campoTipo" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Inicio</label>
                        <input class="form-control" type="date" @bind="campoFechaInicio" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Fin</label>
                        <input class="form-control" type="date" @bind="campoFechaFin" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Docente (Cédula)</label>
                        <input class="form-control" type="number" @bind="campoDocente" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Id</th><th>Nombre Cargo</th><th>Institución</th><th>Tipo</th><th>Fecha Inicio</th><th>Fecha Fin</th><th>Docente</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]</td>
                        <td>@reg["nombre_cargo"]</td>
                        <td>@reg["institucion"]</td>
                        <td>@reg["tipo"]</td>
                        <td>@reg["fecha_inicio"]</td>
                        <td>@reg["fecha_fin"]</td>
                        <td>@reg["docente"]</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en experiecia.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false;
    private string mensaje = string.Empty, campoId = string.Empty;
    private string campoNombreCargo = string.Empty, campoInstitucion = string.Empty;
    private string campoNombre = string.Empty, campoTipo = string.Empty;
    private DateTime? campoFechaInicio = null, campoFechaFin = null;
    private int? campoDocente = null;

    protected override async Task OnInitializedAsync() => await CargarRegistros();

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("experiecia");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoId = string.Empty; campoNombreCargo = string.Empty;
        campoInstitucion = string.Empty; campoNombre = string.Empty; campoTipo = string.Empty;
        campoFechaInicio = null; campoFechaFin = null; campoDocente = null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = reg["id"]?.ToString() ?? "";
        campoNombreCargo = reg["nombre_cargo"]?.ToString() ?? "";
        campoInstitucion = reg["institucion"]?.ToString() ?? "";
        campoNombre = reg["nombre"]?.ToString() ?? "";
        campoTipo = reg["tipo"]?.ToString() ?? "";
        if (DateTime.TryParse(reg["fecha_inicio"]?.ToString(), out DateTime fi)) campoFechaInicio = fi;
        if (DateTime.TryParse(reg["fecha_fin"]?.ToString(), out DateTime ff)) campoFechaFin = ff;
        if (int.TryParse(reg["docente"]?.ToString(), out int d)) campoDocente = d;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["nombre_cargo"] = campoNombreCargo, ["institucion"] = campoInstitucion,
            ["nombre"] = campoNombre, ["tipo"] = campoTipo,
            ["fecha_inicio"] = campoFechaInicio, ["fecha_fin"] = campoFechaFin,
            ["docente"] = campoDocente
        };
        var resultado = editando
            ? await Api.ActualizarAsync("experiecia", "id", campoId, datos)
            : await Api.CrearAsync("experiecia", datos);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        var resultado = await Api.EliminarAsync("experiecia", "id", reg["id"]?.ToString() ?? "");
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }
}