@page "/reconocimientos"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <h3>Reconocimientos</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Reconocimiento</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Reconocimiento" : "Nuevo Reconocimiento")</div>
            <div class="card-body">
                <div class="row">
                    @if (editando)
                    {
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Id</label>
                            <input class="form-control" @bind="campoId" disabled />
                        </div>
                    }
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Tipo</label>
                        <input class="form-control" @bind="campoTipo" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha</label>
                        <input class="form-control" type="date" @bind="campoFecha" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Institución</label>
                        <input class="form-control" @bind="campoInstitucion" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="campoNombre" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Ámbito</label>
                        <input class="form-control" @bind="campoAmbito" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Docente (Cédula)</label>
                        <input class="form-control" type="number" @bind="campoDocente" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Id</th><th>Tipo</th><th>Fecha</th><th>Institución</th><th>Nombre</th><th>Ámbito</th><th>Docente</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]</td>
                        <td>@reg["tipo"]</td>
                        <td>@reg["fecha"]</td>
                        <td>@reg["institucion"]</td>
                        <td>@reg["nombre"]</td>
                        <td>@reg["ambito"]</td>
                        <td>@reg["docente"]</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en reconocimiento.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
        private List<Dictionary<string, object?>> Docente = new();
    
    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false;
    private string mensaje = string.Empty, campoId = string.Empty;
    private string campoTipo = string.Empty, campoInstitucion = string.Empty;
    private string campoNombre = string.Empty, campoAmbito = string.Empty;
    private DateTime? campoFecha = null;
    private int? campoDocente = null;

      protected override async Task OnInitializedAsync()
    {    
        Docente = await Api.ListarAsync("Docente"); 
        await CargarRegistros();
    }


    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("reconocimiento");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoId = string.Empty; campoTipo = string.Empty;
        campoFecha = null; campoInstitucion = string.Empty;
        campoNombre = string.Empty; campoAmbito = string.Empty; campoDocente = null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = reg["id"]?.ToString() ?? "";
        campoTipo = reg["tipo"]?.ToString() ?? "";
        if (DateTime.TryParse(reg["fecha"]?.ToString(), out DateTime f)) campoFecha = f;
        campoInstitucion = reg["institucion"]?.ToString() ?? "";
        campoNombre = reg["nombre"]?.ToString() ?? "";
        campoAmbito = reg["ambito"]?.ToString() ?? "";
        if (int.TryParse(reg["docente"]?.ToString(), out int d)) campoDocente = d;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["tipo"] = campoTipo, ["fecha"] = campoFecha,
            ["institucion"] = campoInstitucion, ["nombre"] = campoNombre,
            ["ambito"] = campoAmbito, ["docente"] = campoDocente
        };
        var resultado = editando
            ? await Api.ActualizarAsync("reconocimiento", "id", campoId, datos)
            : await Api.CrearAsync("reconocimiento", datos);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        var resultado = await Api.EliminarAsync("reconocimiento", "id", reg["id"]?.ToString() ?? "");
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }
}