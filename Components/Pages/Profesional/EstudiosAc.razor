@page "/estudios-ac"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <h3>Estudio — Área Conocimiento</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Relación</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">Nueva Relación Estudio — Área Conocimiento</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Estudio</label>
                        <select class="form-select" @bind="campoEstudio">
                            <option value="">-- Seleccione --</option>
                            @foreach (var e in estudios)
                            {
                                <option value="@e["id"]">@e["titulo"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Área Conocimiento</label>
                        <select class="form-select" @bind="campoArea">
                            <option value="">-- Seleccione --</option>
                            @foreach (var a in areas)
                            {
                                <option value="@a["id"]">@a["area"] — @a["disciplina"]</option>
                            }
                        </select>
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Estudio</th><th>Área Conocimiento</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerNombre(estudios, reg.GetValueOrDefault("estudio"), "id", "titulo")</td>
                        <td>@ObtenerNombreArea(reg.GetValueOrDefault("area_conocimiento"))</td>
                        <td>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en estudio_ac.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> estudios = new();
    private List<Dictionary<string, object?>> areas = new();
    private bool cargando = true, mostrarFormulario = false, exito = false;
    private string mensaje = string.Empty;
    private int? campoEstudio = null, campoArea = null;

    protected override async Task OnInitializedAsync()
    {
        estudios = await Api.ListarAsync("estudios_realizados");
        areas = await Api.ListarAsync("area_conocimiento");
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("estudio_ac");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        campoEstudio = null; campoArea = null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["estudio"] = campoEstudio,
            ["area_conocimiento"] = campoArea
        };
        var resultado = await Api.CrearAsync("estudio_ac", datos);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        int e = Convert.ToInt32(reg.GetValueOrDefault("estudio"));
        int a = Convert.ToInt32(reg.GetValueOrDefault("area_conocimiento"));
        var respuesta = await Api.EliminarAsync("estudio_ac", $"{e}", $"{a}");
        exito = respuesta.exito; mensaje = respuesta.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }

    private string ObtenerNombre(List<Dictionary<string, object?>> lista, object? id, string campoId, string campoNombre)
    {
        if (id == null) return "";
        var item = lista.FirstOrDefault(x => x[campoId]?.ToString() == id.ToString());
        return item?[campoNombre]?.ToString() ?? id.ToString() ?? "";
    }

    private string ObtenerNombreArea(object? id)
    {
        if (id == null) return "";
        var item = areas.FirstOrDefault(x => x["id"]?.ToString() == id.ToString());
        if (item == null) return id.ToString() ?? "";
        return $"{item["area"]} — {item["disciplina"]}";
    }
}