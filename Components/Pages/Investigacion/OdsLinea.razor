@page "/ods-lineas"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <h3>ODS — Línea de Investigación</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Relación</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">Nueva Relación ODS — Línea</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Línea Investigación</label>
                        <select class="form-select" @bind="campoLinea">
                            <option value="">-- Seleccione --</option>
                            @foreach (var l in lineas)
                            {
                                <option value="@l["id"]">@l["nombre"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">ODS</label>
                        <select class="form-select" @bind="campoOds">
                            <option value="">-- Seleccione --</option>
                            @foreach (var o in ods)
                            {
                                <option value="@o["id"]">@o["nombre"]</option>
                            }
                        </select>
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Línea</th><th>ODS</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerNombre(lineas, reg["linea_investigacion"], "id", "nombre")</td>
                        <td>@ObtenerNombre(ods, reg["ods"], "id", "nombre")</td>
                        <td>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> lineas = new();
    private List<Dictionary<string, object?>> ods = new();
    private bool cargando = true, mostrarFormulario = false, exito = false;
    private string mensaje = string.Empty;
    private int? campoLinea = null, campoOds = null;

    protected override async Task OnInitializedAsync()
    {
        lineas = await Api.ListarAsync("linea_investigacion");
        ods = await Api.ListarAsync("objetivos_desarrollo_sostenible");
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("ods_linea");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        campoLinea = null; campoOds = null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["linea_investigacion"] = campoLinea,
            ["ods"] = campoOds
        };
        var resultado = await Api.CrearAsync("ods_linea", datos);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        int l = Convert.ToInt32(reg["linea_investigacion"]);
        int o = Convert.ToInt32(reg["ods"]);
        var respuesta = await Api.EliminarAsync("ods_linea", $"{l}", $"{o}");
        exito = respuesta.exito; mensaje = respuesta.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }

    private string ObtenerNombre(List<Dictionary<string, object?>> lista, object? id, string campoId, string campoNombre)
    {
        if (id == null) return "";
        var item = lista.FirstOrDefault(x => x[campoId]?.ToString() == id.ToString());
        return item?[campoNombre]?.ToString() ?? id.ToString() ?? "";
    }
}