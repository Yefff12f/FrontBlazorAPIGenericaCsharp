@page "/participa-grupos"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <h3>Participación en Grupos de Investigación</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Participación</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">Nueva Participación en Grupo</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Docente</label>
                        <select class="form-select" @bind="campoDocente">
                            <option value="">-- Seleccione --</option>
                            @foreach (var d in docentes)
                            {
                                <option value="@d["cedula"]">@d["nombres"] @d["apellidos"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Grupo Investigación</label>
                        <select class="form-select" @bind="campoGrupo">
                            <option value="">-- Seleccione --</option>
                            @foreach (var g in grupos)
                            {
                                <option value="@g["id"]">@g["nombre"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Categoría</label>
                        <input class="form-control" @bind="campoCategoria" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Convocatoria</label>
                        <input class="form-control" @bind="campoConvocatoria" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Inicio</label>
                        <input class="form-control" type="date"
                            value="@campoFechaIni?.ToString("yyyy-MM-dd")"
                            @onchange="e => campoFechaIni = e.Value?.ToString() is string s && s != string.Empty ? DateTime.Parse(s) : null" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Fin</label>
                        <input class="form-control" type="date"
                            value="@campoFechaFin?.ToString("yyyy-MM-dd")"
                            @onchange="e => campoFechaFin = e.Value?.ToString() is string s && s != string.Empty ? DateTime.Parse(s) : null" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Docente</th><th>Grupo</th><th>Categoría</th><th>Convocatoria</th><th>Fecha Ini</th><th>Fecha Fin</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerNombreDocente(reg["docente"])</td>
                        <td>@ObtenerNombre(grupos, reg["grupo_investigacion"], "id", "nombre")</td>
                        <td>@reg["categoria"]</td>
                        <td>@reg["convocatoria"]</td>
                        <td>@reg["fecha_ini"]</td>
                        <td>@reg["fecha_fin"]</td>
                        <td>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> docentes = new();
    private List<Dictionary<string, object?>> grupos = new();
    private bool cargando = true, mostrarFormulario = false, exito = false;
    private string mensaje = string.Empty, campoCategoria = string.Empty, campoConvocatoria = string.Empty;
    private int? campoDocente = null, campoGrupo = null;
    private DateTime? campoFechaIni = null, campoFechaFin = null;

    protected override async Task OnInitializedAsync()
    {
        docentes = await Api.ListarAsync("docente");
        grupos = await Api.ListarAsync("grupo_investigacion");
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("participa_grupo");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        campoDocente = null; campoGrupo = null; campoCategoria = string.Empty;
        campoConvocatoria = string.Empty; campoFechaIni = null; campoFechaFin = null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["docente"] = campoDocente, ["grupo_investigacion"] = campoGrupo,
            ["categoria"] = campoCategoria, ["convocatoria"] = campoConvocatoria,
            ["fecha_ini"] = campoFechaIni?.ToString("yyyy-MM-dd"),
            ["fecha_fin"] = campoFechaFin?.ToString("yyyy-MM-dd")
        };
        var resultado = await Api.CrearAsync("participa_grupo", datos);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        int doc = Convert.ToInt32(reg["docente"]);
        int grp = Convert.ToInt32(reg["grupo_investigacion"]);
        var respuesta = await Api.EliminarAsync("participa_grupo", $"{doc}", $"{grp}");
        exito = respuesta.exito; mensaje = respuesta.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }

    private string ObtenerNombre(List<Dictionary<string, object?>> lista, object? id, string campoId, string campoNombre)
    {
        if (id == null) return "";
        var item = lista.FirstOrDefault(x => x[campoId]?.ToString() == id.ToString());
        return item?[campoNombre]?.ToString() ?? id.ToString() ?? "";
    }

    private string ObtenerNombreDocente(object? id)
    {
        if (id == null) return "";
        var item = docentes.FirstOrDefault(x => x["cedula"]?.ToString() == id.ToString());
        if (item == null) return id.ToString() ?? "";
        return $"{item["nombres"]} {item["apellidos"]}";
    }
}