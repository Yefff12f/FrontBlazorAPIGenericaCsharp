@page "/docentes-departamentos"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <h3>Docente — Departamento</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Relación</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Relación" : "Nueva Relación")</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Docente (ID)</label>
                        <input class="form-control" type="number" @bind="campoDocente" disabled="@editando" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Departamento (ID)</label>
                        <input class="form-control" type="number" @bind="campoDepartamento" disabled="@editando" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Dedicación</label>
                        <input class="form-control" @bind="campoDedicacion" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Modalidad</label>
                        <input class="form-control" @bind="campoModalidad" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Ingreso</label>
                        <input class="form-control" type="date" @bind="campoFechaIngreso" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Salida</label>
                        <input class="form-control" type="date" @bind="campoFechaSalida" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Docente</th><th>Departamento</th><th>Dedicación</th><th>Modalidad</th><th>Fecha Ingreso</th><th>Fecha Salida</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["docente"]</td>
                        <td>@reg["departamento"]</td>
                        <td>@reg["dedicacion"]</td>
                        <td>@reg["modalidad"]</td>
                        <td>@reg["fecha_ingreso"]</td>
                        <td>@reg["fecha_salida"]</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en docente_departamento.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> docentes = new();
    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false;
    private string mensaje = string.Empty, campoDedicacion = string.Empty, campoModalidad = string.Empty;
    private int? campoDocente = null, campoDepartamento = null;
    private DateTime? campoFechaIngreso = null, campoFechaSalida = null;

    
   protected override async Task OnInitializedAsync()
    {
        docentes = await Api.ListarAsync("docente");
        await CargarRegistros();
    }    



    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("docente_departamento");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoDocente = null; campoDepartamento = null;
        campoDedicacion = string.Empty; campoModalidad = string.Empty;
        campoFechaIngreso = null; campoFechaSalida = null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        if (int.TryParse(reg["docente"]?.ToString(), out int doc)) campoDocente = doc;
        if (int.TryParse(reg["departamento"]?.ToString(), out int dep)) campoDepartamento = dep;
        campoDedicacion = reg["dedicacion"]?.ToString() ?? "";
        campoModalidad = reg["modalidad"]?.ToString() ?? "";
        if (DateTime.TryParse(reg["fecha_ingreso"]?.ToString(), out DateTime fi)) campoFechaIngreso = fi;
        if (DateTime.TryParse(reg["fecha_salida"]?.ToString(), out DateTime fs)) campoFechaSalida = fs;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["docente"] = campoDocente, ["departamento"] = campoDepartamento,
            ["dedicacion"] = campoDedicacion, ["modalidad"] = campoModalidad,
            ["fecha_ingreso"] = campoFechaIngreso, ["fecha_salida"] = campoFechaSalida
        };
        (bool exito, string mensaje) resultado;
        if (editando)
            resultado = await Api.ActualizarAsync("docente_departamento", $"{campoDocente}", $"{campoDepartamento}", datos);
        else
            resultado = await Api.CrearAsync("docente_departamento", datos);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        int doc = Convert.ToInt32(reg["docente"]);
        int dep = Convert.ToInt32(reg["departamento"]);
        var respuesta = await Api.EliminarAsync("docente_departamento", $"{doc}", $"{dep}");
        exito = respuesta.exito; mensaje = respuesta.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }
}