@page "/programas-ci"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <h3>Programa — Car. Innovación</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Relación</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">Nueva Relación Programa — Car. Innovación</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Programa</label>
                        <select class="form-select" @bind="campoPrograma">
                            <option value="">-- Seleccione --</option>
                            @foreach (var p in programas)
                            {
                                <option value="@p["id"]">@p["nombre"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Car. Innovación</label>
                        <select class="form-select" @bind="campoCi">
                            <option value="">-- Seleccione --</option>
                            @foreach (var c in carInnovaciones)
                            {
                                <option value="@c["id"]">@c["nombre"]</option>
                            }
                        </select>
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Programa</th><th>Car. Innovación</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerNombre(programas, reg["programa"], "id", "nombre")</td>
                        <td>@ObtenerNombre(carInnovaciones, reg["car_innovacion"], "id", "nombre")</td>
                        <td>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en programa_ci.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> programas = new();       // ✅ una sola vez
    private List<Dictionary<string, object?>> carInnovaciones = new(); // ✅ una sola vez
    private bool cargando = true, mostrarFormulario = false, exito = false;
    private string mensaje = string.Empty;
    private int? campoPrograma = null, campoCi = null;

    protected override async Task OnInitializedAsync()
    {
        programas = await Api.ListarAsync("programa");
        carInnovaciones = await Api.ListarAsync("car_innovacion");
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("programa_ci");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        campoPrograma = null; campoCi = null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["programa"] = campoPrograma,
            ["car_innovacion"] = campoCi
        };
        var resultado = await Api.CrearAsync("programa_ci", datos);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        int p = Convert.ToInt32(reg["programa"]);
        int ci = Convert.ToInt32(reg["car_innovacion"]);
        var respuesta = await Api.EliminarAsync("programa_ci", $"{p}", $"{ci}");
        exito = respuesta.exito; mensaje = respuesta.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }

    private string ObtenerNombre(List<Dictionary<string, object?>> lista, object? id, string campoId, string campoNombre)
    {
        if (id == null) return "";
        var item = lista.FirstOrDefault(x => x[campoId]?.ToString() == id.ToString());
        return item?[campoNombre]?.ToString() ?? id.ToString() ?? "";
    }
}