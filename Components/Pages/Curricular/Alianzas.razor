@page "/alianzas"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <h3>Alianzas</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Alianza</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Alianza" : "Nueva Alianza")</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Aliado</label>
                        <select class="form-select" @bind="campoAliado" disabled="@editando">
                            <option value="">-- Seleccione --</option>
                            @foreach (var a in aliados)
                            {
                                <option value="@a["id"]">@a["nombre"] @a["apellidos"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Departamento (ID)</label>
                        <input class="form-control" type="number" @bind="campoDepartamento" disabled="@editando" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Docente</label>
                        <select class="form-select" @bind="campoDocente">
                            <option value="">-- Seleccione --</option>
                            @foreach (var d in docentes)
                            {
                                <option value="@d["cedula"]">@d["nombres"] @d["apellidos"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Inicio</label>
                        <input class="form-control" type="date"
                            value="@campoFechaInicio?.ToString("yyyy-MM-dd")"
                            @onchange="e => campoFechaInicio = e.Value?.ToString() is string s && s != string.Empty ? DateTime.Parse(s) : null" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Fin</label>
                        <input class="form-control" type="date"
                            value="@campoFechaFin?.ToString("yyyy-MM-dd")"
                            @onchange="e => campoFechaFin = e.Value?.ToString() is string s && s != string.Empty ? DateTime.Parse(s) : null" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Aliado</th><th>Departamento</th><th>Docente</th><th>Fecha Inicio</th><th>Fecha Fin</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerNombreAliado(reg["aliado"])</td>
                        <td>@reg["departamento"]</td>
                        <td>@ObtenerNombreDocente(reg["docente"])</td>
                        <td>@reg["fecha_inicio"]</td>
                        <td>@reg["fecha_fin"]</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en alianza.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> aliados = new();
    private List<Dictionary<string, object?>> docentes = new();
    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false;
    private string mensaje = string.Empty;
    private int? campoAliado = null, campoDepartamento = null, campoDocente = null;
    private DateTime? campoFechaInicio = null, campoFechaFin = null;

    protected override async Task OnInitializedAsync()
    {
        aliados = await Api.ListarAsync("aliado");
        docentes = await Api.ListarAsync("docente");
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("alianza");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoAliado = null; campoDepartamento = null;
        campoDocente = null; campoFechaInicio = null; campoFechaFin = null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        if (int.TryParse(reg["aliado"]?.ToString(), out int a)) campoAliado = a;
        if (int.TryParse(reg["departamento"]?.ToString(), out int d)) campoDepartamento = d;
        if (int.TryParse(reg["docente"]?.ToString(), out int doc)) campoDocente = doc;
        if (DateTime.TryParse(reg["fecha_inicio"]?.ToString(), out DateTime fi)) campoFechaInicio = fi;
        if (DateTime.TryParse(reg["fecha_fin"]?.ToString(), out DateTime ff)) campoFechaFin = ff;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["aliado"] = campoAliado, ["departamento"] = campoDepartamento,
            ["docente"] = campoDocente,
            ["fecha_inicio"] = campoFechaInicio?.ToString("yyyy-MM-dd"),
            ["fecha_fin"] = campoFechaFin?.ToString("yyyy-MM-dd")
        };
        (bool exito, string mensaje) resultado;
        if (editando)
            resultado = await Api.ActualizarAsync("alianza", $"{campoAliado}", $"{campoDepartamento}", datos);
        else
            resultado = await Api.CrearAsync("alianza", datos);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        int a = Convert.ToInt32(reg["aliado"]);
        int d = Convert.ToInt32(reg["departamento"]);
        var respuesta = await Api.EliminarAsync("alianza", $"{a}", $"{d}");
        exito = respuesta.exito; mensaje = respuesta.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }

    private string ObtenerNombreAliado(object? id)
    {
        if (id == null) return "";
        var item = aliados.FirstOrDefault(x => x["id"]?.ToString() == id.ToString());
        if (item == null) return id.ToString() ?? "";
        return $"{item["nombre"]} {item["apellidos"]}";
    }

    private string ObtenerNombreDocente(object? id)
    {
        if (id == null) return "";
        var item = docentes.FirstOrDefault(x => x["cedula"]?.ToString() == id.ToString());
        if (item == null) return id.ToString() ?? "";
        return $"{item["nombres"]} {item["apellidos"]}";
    }
}