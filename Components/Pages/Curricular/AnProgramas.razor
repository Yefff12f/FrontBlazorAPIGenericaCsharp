@page "/an-programas"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <h3>Aspecto Normativo — Programa</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Relación</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">Nueva Relación Aspecto Normativo — Programa</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">ID Aspecto Normativo</label>
                        <input class="form-control" type="number" @bind="campoAspecto" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">ID Programa</label>
                        <input class="form-control" type="number" @bind="campoPrograma" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Aspecto Normativo</th><th>Programa</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["aspecto_normativo"]</td>
                        <td>@reg["programa"]</td>
                        <td>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en an_programa.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true, mostrarFormulario = false, exito = false;
    private string mensaje = string.Empty;
    private int? campoAspecto = null, campoPrograma = null;
    
    private List<Dictionary<string, object?>> aspectos = new();
    private List<Dictionary<string, object?>> programas = new();

    protected override async Task OnInitializedAsync()
    {
        aspectos = await Api.ListarAsync("aspecto_normativo");
        programas = await Api.ListarAsync("programa");
        await CargarRegistros();
    }
    
    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("an_programa");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        campoAspecto = null; campoPrograma = null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["aspecto_normativo"] = campoAspecto,
            ["programa"] = campoPrograma
        };
        var resultado = await Api.CrearAsync("an_programa", datos);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        int a = Convert.ToInt32(reg["aspecto_normativo"]);
        int p = Convert.ToInt32(reg["programa"]);
        var respuesta = await Api.EliminarAsync("an_programa", $"{a}", $"{p}");
        exito = respuesta.exito; mensaje = respuesta.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }
}