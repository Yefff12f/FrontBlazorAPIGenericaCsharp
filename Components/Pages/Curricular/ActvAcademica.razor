@page "/actvs-academicas"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <h3>Actividades Académicas</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Actividad</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Actividad" : "Nueva Actividad")</div>
            <div class="card-body">
                <div class="row">
                    @if (editando)
                    {
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Id</label>
                            <input class="form-control" @bind="campoId" disabled />
                        </div>
                    }
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Num Créditos</label>
                        <input class="form-control" type="number" @bind="campoNumCreditos" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Tipo</label>
                        <input class="form-control" @bind="campoTipo" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Área Formación</label>
                        <input class="form-control" @bind="campoAreaFormacion" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Exeq</label>
                        <input class="form-check-input" type="checkbox" @bind="campoExeq" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">H Nohdi</label>
                        <input class="form-control" type="number" @bind="campoHNohdi" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">H Unidad</label>
                        <input class="form-control" type="number" @bind="campoHUnidad" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Diploma</label>
                        <input class="form-control" @bind="campoDiploma" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Entidad Apoyo</label>
                        <input class="form-control" @bind="campoEntidadApoyo" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">País Apoyo</label>
                        <input class="form-control" @bind="campoPaisApoyo" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Dinero</label>
                        <input class="form-control" type="number" @bind="campoDinero" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Id</th><th>Créditos</th><th>Tipo</th><th>Área Formación</th>
                    <th>Diploma</th><th>Entidad Apoyo</th><th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]</td>
                        <td>@reg["num_creditos"]</td>
                        <td>@reg["tipo"]</td>
                        <td>@reg["area_formacion"]</td>
                        <td>@reg["diploma"]</td>
                        <td>@reg["entidad_apoyo"]</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en actv_academica.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false;
    private string mensaje = string.Empty, campoId = string.Empty;
    private string campoTipo = string.Empty, campoAreaFormacion = string.Empty;
    private string campoDiploma = string.Empty, campoEntidadApoyo = string.Empty, campoPaisApoyo = string.Empty;
    private int? campoNumCreditos = null, campoHNohdi = null, campoHUnidad = null, campoDinero = null;
    private bool campoExeq = false;

    protected override async Task OnInitializedAsync() => await CargarRegistros();

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("actv_academica");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoId = string.Empty; campoNumCreditos = null;
        campoTipo = string.Empty; campoAreaFormacion = string.Empty; campoExeq = false;
        campoHNohdi = null; campoHUnidad = null; campoDiploma = string.Empty;
        campoEntidadApoyo = string.Empty; campoPaisApoyo = string.Empty; campoDinero = null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = reg["id"]?.ToString() ?? "";
        campoTipo = reg["tipo"]?.ToString() ?? "";
        campoAreaFormacion = reg["area_formacion"]?.ToString() ?? "";
        campoDiploma = reg["diploma"]?.ToString() ?? "";
        campoEntidadApoyo = reg["entidad_apoyo"]?.ToString() ?? "";
        campoPaisApoyo = reg["pais_apoyo"]?.ToString() ?? "";
        campoExeq = reg["exeq"] as bool? ?? false;
        if (int.TryParse(reg["num_creditos"]?.ToString(), out int nc)) campoNumCreditos = nc;
        if (int.TryParse(reg["h_nohdi"]?.ToString(), out int hn)) campoHNohdi = hn;
        if (int.TryParse(reg["h_unidad"]?.ToString(), out int hu)) campoHUnidad = hu;
        if (int.TryParse(reg["dinero"]?.ToString(), out int d)) campoDinero = d;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["num_creditos"] = campoNumCreditos, ["tipo"] = campoTipo,
            ["area_formacion"] = campoAreaFormacion, ["exeq"] = campoExeq,
            ["h_nohdi"] = campoHNohdi, ["h_unidad"] = campoHUnidad,
            ["diploma"] = campoDiploma, ["entidad_apoyo"] = campoEntidadApoyo,
            ["pais_apoyo"] = campoPaisApoyo, ["dinero"] = campoDinero
        };
        var resultado = editando
            ? await Api.ActualizarAsync("actv_academica", "id", campoId, datos)
            : await Api.CrearAsync("actv_academica", datos);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        var resultado = await Api.EliminarAsync("actv_academica", "id", reg["id"]?.ToString() ?? "");
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }
}