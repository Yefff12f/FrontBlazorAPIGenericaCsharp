@page "/aa-rcs"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <h3>Actividad Académica — Registro Calificado</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Relación</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Relación" : "Nueva Relación")</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Actv Académica</label>
                        <select class="form-select" @bind="campoActv" disabled="@editando">
                            <option value="">-- Seleccione --</option>
                            @foreach (var a in actvs)
                            {
                                <option value="@a["id"]">@a["tipo"] — @a["area_formacion"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Registro Calificado</label>
                        <select class="form-select" @bind="campoRc" disabled="@editando">
                            <option value="">-- Seleccione --</option>
                            @foreach (var r in registrosCal)
                            {
                                <option value="@r["id"]">@r["id"] — @r["metodologia"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Componente</label>
                        <input class="form-control" @bind="campoComponente" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Semestre</label>
                        <input class="form-control" @bind="campoSemestre" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Actv Académica</th><th>Registro Calificado</th><th>Componente</th><th>Semestre</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerNombreActv(reg["actv_academicas_idcurso"])</td>
                        <td>@ObtenerNombreRc(reg["registro_calificado_codigo"])</td>
                        <td>@reg["componente"]</td>
                        <td>@reg["semestre"]</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en aa_rc.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> actvs = new();         // ✅ AGREGADO
    private List<Dictionary<string, object?>> registrosCal = new();  // ✅ AGREGADO
    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false;
    private string mensaje = string.Empty, campoComponente = string.Empty, campoSemestre = string.Empty;
    private int? campoActv = null, campoRc = null;

    protected override async Task OnInitializedAsync()
    {
        actvs = await Api.ListarAsync("actv_academica");          // ✅ usa variable declarada
        registrosCal = await Api.ListarAsync("registro_calificado"); // ✅ nombre consistente
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("aa_rc");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoActv = null; campoRc = null;
        campoComponente = string.Empty; campoSemestre = string.Empty;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        if (int.TryParse(reg["actv_academicas_idcurso"]?.ToString(), out int a)) campoActv = a;
        if (int.TryParse(reg["registro_calificado_codigo"]?.ToString(), out int rc)) campoRc = rc;
        campoComponente = reg["componente"]?.ToString() ?? "";
        campoSemestre = reg["semestre"]?.ToString() ?? "";
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["actv_academicas_idcurso"] = campoActv,
            ["registro_calificado_codigo"] = campoRc,
            ["componente"] = campoComponente,
            ["semestre"] = campoSemestre
        };
        (bool exito, string mensaje) resultado;
        if (editando)
            resultado = await Api.ActualizarAsync("aa_rc", $"{campoActv}", $"{campoRc}", datos);
        else
            resultado = await Api.CrearAsync("aa_rc", datos);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        int a = Convert.ToInt32(reg["actv_academicas_idcurso"]);
        int rc = Convert.ToInt32(reg["registro_calificado_codigo"]);
        var respuesta = await Api.EliminarAsync("aa_rc", $"{a}", $"{rc}");
        exito = respuesta.exito; mensaje = respuesta.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }

    private string ObtenerNombreActv(object? id)
    {
        if (id == null) return "";
        var item = actvs.FirstOrDefault(x => x["id"]?.ToString() == id.ToString());
        if (item == null) return id.ToString() ?? "";
        return $"{item["tipo"]} — {item["area_formacion"]}";
    }

    private string ObtenerNombreRc(object? id)
    {
        if (id == null) return "";
        var item = registrosCal.FirstOrDefault(x => x["id"]?.ToString() == id.ToString());
        if (item == null) return id.ToString() ?? "";
        return $"{item["id"]} — {item["metodologia"]}";
    }
}