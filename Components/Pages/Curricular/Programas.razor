@page "/programas"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <h3>Programas</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Programa</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header fw-bold">@(editando ? "Editar Programa" : "Nuevo Programa")</div>
            <div class="card-body">
                <div class="row">
                    @if (editando)
                    {
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Id</label>
                            <input class="form-control" @bind="campoId" disabled />
                        </div>
                    }
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="campoNombre" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Tipo</label>
                        <input class="form-control" @bind="campoTipo" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Creación</label>
                        <input class="form-control" type="date"
                            value="@campoFechaCreacion?.ToString("yyyy-MM-dd")"
                            @onchange="e => campoFechaCreacion = e.Value?.ToString() is string s && s != string.Empty ? DateTime.Parse(s) : null" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Num Créditos</label>
                        <input class="form-control" type="number" @bind="campoNumCreditos" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Cant Semestres</label>
                        <input class="form-control" type="number" @bind="campoCantSemestres" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Actualización</label>
                        <input class="form-control" type="date"
                            value="@campoFechaActualizacion?.ToString("yyyy-MM-dd")"
                            @onchange="e => campoFechaActualizacion = e.Value?.ToString() is string s && s != string.Empty ? DateTime.Parse(s) : null" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">País</label>
                        <input class="form-control" @bind="campoPais" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Ciudad</label>
                        <input class="form-control" @bind="campoCiudad" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Facultad</label>
                        <select class="form-select" @bind="campoFacultad">
                            <option value="">-- Seleccione --</option>
                            @foreach (var f in facultades)
                            {
                                <option value="@f["id"]">@f["nombre"]</option>
                            }
                        </select>
                    </div>
                </div>

                <hr />
                <h6 class="text-muted mb-2">Características de Innovación</h6>
                <div class="row mb-2">
                    <div class="col-md-9">
                        <select class="form-select" @bind="ciSeleccionada">
                            <option value="">-- Seleccione --</option>
                            @foreach (var c in carInnovaciones)
                            {
                                <option value="@c["id"]">@c["nombre"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-outline-primary w-100" @onclick="AgregarCi">+ Agregar</button>
                    </div>
                </div>
                @if (cisAgregadas.Any())
                {
                    <table class="table table-sm table-bordered mb-3">
                        <thead class="table-secondary"><tr><th>Característica</th><th>Acciones</th></tr></thead>
                        <tbody>
                            @foreach (var id in cisAgregadas)
                            {
                                <tr>
                                    <td>@ObtenerNombre(carInnovaciones, id, "id", "nombre")</td>
                                    <td><button class="btn btn-danger btn-sm" @onclick="() => QuitarCi(id)">Quitar</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-light border mb-3">No hay características de innovación agregadas.</div>
                }

                <hr />
                <h6 class="text-muted mb-2">Aspectos Normativos</h6>
                <div class="row mb-2">
                    <div class="col-md-9">
                        <select class="form-select" @bind="aspectoSeleccionado">
                            <option value="">-- Seleccione --</option>
                            @foreach (var a in aspectosNormativos)
                            {
                                <option value="@a["id"]">@a["aspecto_norm_ac"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-outline-primary w-100" @onclick="AgregarAspecto">+ Agregar</button>
                    </div>
                </div>
                @if (aspectosAgregados.Any())
                {
                    <table class="table table-sm table-bordered mb-3">
                        <thead class="table-secondary"><tr><th>Aspecto</th><th>Acciones</th></tr></thead>
                        <tbody>
                            @foreach (var id in aspectosAgregados)
                            {
                                <tr>
                                    <td>@ObtenerNombre(aspectosNormativos, id, "id", "aspecto_norm_ac")</td>
                                    <td><button class="btn btn-danger btn-sm" @onclick="() => QuitarAspecto(id)">Quitar</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-light border mb-3">No hay aspectos normativos agregados.</div>
                }

                <hr />
                <h6 class="text-muted mb-2">Áreas de Conocimiento</h6>
                <div class="row mb-2">
                    <div class="col-md-9">
                        <select class="form-select" @bind="areaSeleccionada">
                            <option value="">-- Seleccione --</option>
                            @foreach (var a in areasConocimiento)
                            {
                                <option value="@a["id"]">@ObtenerNombreArea(a)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-outline-primary w-100" @onclick="AgregarArea">+ Agregar</button>
                    </div>
                </div>
                @if (areasAgregadas.Any())
                {
                    <table class="table table-sm table-bordered mb-3">
                        <thead class="table-secondary"><tr><th>Área</th><th>Acciones</th></tr></thead>
                        <tbody>
                            @foreach (var id in areasAgregadas)
                            {
                                <tr>
                                    <td>@ObtenerNombreArea(id)</td>
                                    <td><button class="btn btn-danger btn-sm" @onclick="() => QuitarArea(id)">Quitar</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-light border mb-3">No hay áreas de conocimiento agregadas.</div>
                }

                <hr />
                <h6 class="text-muted mb-2">Prácticas y Estrategias</h6>
                <div class="row mb-2">
                    <div class="col-md-9">
                        <select class="form-select" @bind="practicaSeleccionada">
                            <option value="">-- Seleccione --</option>
                            @foreach (var p in practicas)
                            {
                                <option value="@p["id"]">@p["nombre"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-outline-primary w-100" @onclick="AgregarPractica">+ Agregar</button>
                    </div>
                </div>
                @if (practicasAgregadas.Any())
                {
                    <table class="table table-sm table-bordered mb-3">
                        <thead class="table-secondary"><tr><th>Práctica</th><th>Acciones</th></tr></thead>
                        <tbody>
                            @foreach (var id in practicasAgregadas)
                            {
                                <tr>
                                    <td>@ObtenerNombre(practicas, id, "id", "nombre")</td>
                                    <td><button class="btn btn-danger btn-sm" @onclick="() => QuitarPractica(id)">Quitar</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-light border mb-3">No hay prácticas agregadas.</div>
                }

                <hr />
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Id</th><th>Nombre</th><th>Tipo</th><th>Créditos</th><th>Semestres</th><th>Facultad</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]</td>
                        <td>@reg["nombre"]</td>
                        <td>@reg["tipo"]</td>
                        <td>@reg["num_creditos"]</td>
                        <td>@reg["cant_semestres"]</td>
                        <td>@ObtenerNombre(facultades, reg["facultad"], "id", "nombre")</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en programa.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> facultades = new();
    private List<Dictionary<string, object?>> carInnovaciones = new();
    private List<Dictionary<string, object?>> aspectosNormativos = new();
    private List<Dictionary<string, object?>> areasConocimiento = new();
    private List<Dictionary<string, object?>> practicas = new();

    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false;
    private string mensaje = string.Empty, campoId = string.Empty;
    private string campoNombre = string.Empty, campoTipo = string.Empty;
    private string campoPais = string.Empty, campoCiudad = string.Empty;
    private DateTime? campoFechaCreacion = null, campoFechaActualizacion = null;
    private int? campoNumCreditos = null, campoCantSemestres = null, campoFacultad = null;

    private List<int> cisAgregadas = new();
    private List<int> aspectosAgregados = new();
    private List<int> areasAgregadas = new();
    private List<int> practicasAgregadas = new();

    private int? ciSeleccionada = null, aspectoSeleccionado = null, areaSeleccionada = null, practicaSeleccionada = null;

    protected override async Task OnInitializedAsync()
    {
        facultades = await Api.ListarAsync("facultad");
        carInnovaciones = await Api.ListarAsync("car_innovacion");
        aspectosNormativos = await Api.ListarAsync("aspecto_normativo");
        areasConocimiento = await Api.ListarAsync("area_conocimiento");
        practicas = await Api.ListarAsync("practica_estrategia");
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("programa");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoId = string.Empty; campoNombre = string.Empty;
        campoTipo = string.Empty; campoPais = string.Empty; campoCiudad = string.Empty;
        campoFechaCreacion = null; campoFechaActualizacion = null;
        campoNumCreditos = null; campoCantSemestres = null; campoFacultad = null;
        cisAgregadas = new(); aspectosAgregados = new(); areasAgregadas = new(); practicasAgregadas = new();
        ciSeleccionada = null; aspectoSeleccionado = null; areaSeleccionada = null; practicaSeleccionada = null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = reg["id"]?.ToString() ?? "";
        campoNombre = reg["nombre"]?.ToString() ?? "";
        campoTipo = reg["tipo"]?.ToString() ?? "";
        campoPais = reg["pais"]?.ToString() ?? "";
        campoCiudad = reg["ciudad"]?.ToString() ?? "";
        if (DateTime.TryParse(reg["fecha_creacion"]?.ToString(), out DateTime fc)) campoFechaCreacion = fc;
        if (DateTime.TryParse(reg["fecha_actualizacion"]?.ToString(), out DateTime fa)) campoFechaActualizacion = fa;
        if (int.TryParse(reg["num_creditos"]?.ToString(), out int nc)) campoNumCreditos = nc;
        if (int.TryParse(reg["cant_semestres"]?.ToString(), out int cs)) campoCantSemestres = cs;
        if (int.TryParse(reg["facultad"]?.ToString(), out int fac)) campoFacultad = fac;

        var todasCi = await Api.ListarAsync("programa_ci");
        cisAgregadas = todasCi
            .Where(x => x["programa"]?.ToString() == campoId)
            .Select(x => Convert.ToInt32(x["car_innovacion"]))
            .ToList();

        var todosAspectos = await Api.ListarAsync("an_programa");
        aspectosAgregados = todosAspectos
            .Where(x => x["programa"]?.ToString() == campoId)
            .Select(x => Convert.ToInt32(x["aspecto_normativo"]))
            .ToList();

        var todasAreas = await Api.ListarAsync("programa_ac");
        areasAgregadas = todasAreas
            .Where(x => x["programa"]?.ToString() == campoId)
            .Select(x => Convert.ToInt32(x["area_conocimiento"]))
            .ToList();

        var todasPracticas = await Api.ListarAsync("programa_pe");
        practicasAgregadas = todasPracticas
            .Where(x => x["programa"]?.ToString() == campoId)
            .Select(x => Convert.ToInt32(x["practica_estrategia"]))
            .ToList();

        ciSeleccionada = null; aspectoSeleccionado = null; areaSeleccionada = null; practicaSeleccionada = null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void AgregarCi() { if (ciSeleccionada == null || cisAgregadas.Contains(ciSeleccionada.Value)) return; cisAgregadas.Add(ciSeleccionada.Value); ciSeleccionada = null; }
    private void QuitarCi(int id) => cisAgregadas.Remove(id);

    private void AgregarAspecto() { if (aspectoSeleccionado == null || aspectosAgregados.Contains(aspectoSeleccionado.Value)) return; aspectosAgregados.Add(aspectoSeleccionado.Value); aspectoSeleccionado = null; }
    private void QuitarAspecto(int id) => aspectosAgregados.Remove(id);

    private void AgregarArea() { if (areaSeleccionada == null || areasAgregadas.Contains(areaSeleccionada.Value)) return; areasAgregadas.Add(areaSeleccionada.Value); areaSeleccionada = null; }
    private void QuitarArea(int id) => areasAgregadas.Remove(id);

    private void AgregarPractica() { if (practicaSeleccionada == null || practicasAgregadas.Contains(practicaSeleccionada.Value)) return; practicasAgregadas.Add(practicaSeleccionada.Value); practicaSeleccionada = null; }
    private void QuitarPractica(int id) => practicasAgregadas.Remove(id);

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["nombre"] = campoNombre,
            ["tipo"] = campoTipo,
            ["fecha_creacion"] = campoFechaCreacion?.ToString("yyyy-MM-dd"),
            ["num_creditos"] = campoNumCreditos,
            ["cant_semestres"] = campoCantSemestres,
            ["fecha_actualizacion"] = campoFechaActualizacion?.ToString("yyyy-MM-dd"),
            ["pais"] = campoPais,
            ["ciudad"] = campoCiudad,
            ["facultad"] = campoFacultad
        };

        (bool exito, string mensaje) resultado = editando
            ? await Api.ActualizarAsync("programa", "id", campoId, datos)
            : await Api.CrearAsync("programa", datos);

        if (!resultado.exito)
        {
            exito = false; mensaje = resultado.mensaje; return;
        }

        string programaId = campoId;
        if (!editando)
        {
            var todos = await Api.ListarAsync("programa");
            programaId = todos.LastOrDefault()?["id"]?.ToString() ?? "";
        }

        if (editando)
        {
            var existentesCi = await Api.ListarAsync("programa_ci");
            foreach (var item in existentesCi.Where(x => x["programa"]?.ToString() == programaId))
                await Api.EliminarAsync("programa_ci", programaId, item["car_innovacion"]?.ToString() ?? "");

            var existentesAspectos = await Api.ListarAsync("an_programa");
            foreach (var item in existentesAspectos.Where(x => x["programa"]?.ToString() == programaId))
                await Api.EliminarAsync("an_programa", item["aspecto_normativo"]?.ToString() ?? "", programaId);

            var existentesAreas = await Api.ListarAsync("programa_ac");
            foreach (var item in existentesAreas.Where(x => x["programa"]?.ToString() == programaId))
                await Api.EliminarAsync("programa_ac", programaId, item["area_conocimiento"]?.ToString() ?? "");

            var existentesPracticas = await Api.ListarAsync("programa_pe");
            foreach (var item in existentesPracticas.Where(x => x["programa"]?.ToString() == programaId))
                await Api.EliminarAsync("programa_pe", programaId, item["practica_estrategia"]?.ToString() ?? "");
        }

        foreach (var id in cisAgregadas)
            await Api.CrearAsync("programa_ci", new Dictionary<string, object?> { ["programa"] = int.Parse(programaId), ["car_innovacion"] = id });

        foreach (var id in aspectosAgregados)
            await Api.CrearAsync("an_programa", new Dictionary<string, object?> { ["aspecto_normativo"] = id, ["programa"] = int.Parse(programaId) });

        foreach (var id in areasAgregadas)
            await Api.CrearAsync("programa_ac", new Dictionary<string, object?> { ["programa"] = int.Parse(programaId), ["area_conocimiento"] = id });

        foreach (var id in practicasAgregadas)
            await Api.CrearAsync("programa_pe", new Dictionary<string, object?> { ["programa"] = int.Parse(programaId), ["practica_estrategia"] = id });

        exito = true;
        mensaje = editando ? "Programa actualizado correctamente" : "Programa creado correctamente";
        mostrarFormulario = false;
        await CargarRegistros();
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        var resultado = await Api.EliminarAsync("programa", "id", reg["id"]?.ToString() ?? "");
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }

    private string ObtenerNombre(List<Dictionary<string, object?>> lista, object? id, string campoId, string campoNombre)
    {
        if (id == null) return "";
        var item = lista.FirstOrDefault(x => x[campoId]?.ToString() == id.ToString());
        return item?[campoNombre]?.ToString() ?? id.ToString() ?? "";
    }

    private string ObtenerNombreArea(Dictionary<string, object?>? item)
    {
        if (item == null) return "";
        var area = item["area"]?.ToString() ?? "";
        var disciplina = item["disciplina"]?.ToString() ?? "";
        return string.IsNullOrWhiteSpace(disciplina) ? area : $"{area} - {disciplina}";
    }

    private string ObtenerNombreArea(int id)
    {
        var item = areasConocimiento.FirstOrDefault(x => x["id"]?.ToString() == id.ToString());
        return ObtenerNombreArea(item);
    }
}
