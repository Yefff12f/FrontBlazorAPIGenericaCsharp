@page "/registros-calificados"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <h3>Registros Calificados</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Registro</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header fw-bold">@(editando ? "Editar Registro" : "Nuevo Registro")</div>
            <div class="card-body">
                <div class="row">
                    @if (editando)
                    {
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Id</label>
                            <input class="form-control" @bind="campoId" disabled />
                        </div>
                    }
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Cant Preg</label>
                        <input class="form-control" @bind="campoCantPreg" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Calif Preg</label>
                        <input class="form-control" @bind="campoCalifPreg" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">H Actv Académica</label>
                        <input class="form-control" @bind="campoHActv" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Inicio</label>
                        <input class="form-control" type="date"
                            value="@campoFechaIni?.ToString("yyyy-MM-dd")"
                            @onchange="e => campoFechaIni = e.Value?.ToString() is string s && s != string.Empty ? DateTime.Parse(s) : null" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Fin</label>
                        <input class="form-control" type="date"
                            value="@campoFechaFin?.ToString("yyyy-MM-dd")"
                            @onchange="e => campoFechaFin = e.Value?.ToString() is string s && s != string.Empty ? DateTime.Parse(s) : null" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Duración Años</label>
                        <input class="form-control" @bind="campoDuracion" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Docente Semestres</label>
                        <input class="form-control" @bind="campoDocenteSemestres" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Metodología</label>
                        <input class="form-control" @bind="campoMetodologia" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Tipo Titulación</label>
                        <input class="form-control" @bind="campoTipoTitulacion" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Programa</label>
                        <select class="form-select" @bind="campoPrograma">
                            <option value="">-- Seleccione --</option>
                            @foreach (var p in programas)
                            {
                                <option value="@p["id"]">@p["nombre"]</option>
                            }
                        </select>
                    </div>
                </div>

                <hr />
                <h6 class="text-muted mb-2">Enfoques</h6>
                <div class="row mb-2">
                    <div class="col-md-9">
                        <select class="form-select" @bind="enfoqueSeleccionado">
                            <option value="">-- Seleccione --</option>
                            @foreach (var e in enfoques)
                            {
                                <option value="@e["id"]">@e["nombre"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-outline-primary w-100" @onclick="AgregarEnfoque">+ Agregar</button>
                    </div>
                </div>
                @if (enfoquesAgregados.Any())
                {
                    <table class="table table-sm table-bordered mb-3">
                        <thead class="table-secondary"><tr><th>Enfoque</th><th>Acciones</th></tr></thead>
                        <tbody>
                            @foreach (var id in enfoquesAgregados)
                            {
                                <tr>
                                    <td>@ObtenerNombre(enfoques, id, "id", "nombre")</td>
                                    <td><button class="btn btn-danger btn-sm" @onclick="() => QuitarEnfoque(id)">Quitar</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-light border mb-3">No hay enfoques agregados.</div>
                }

                <hr />
                <h6 class="text-muted mb-2">Actividades Académicas</h6>
                <div class="row mb-2">
                    <div class="col-md-4">
                        <select class="form-select" @bind="actvSeleccionada">
                            <option value="">-- Seleccione --</option>
                            @foreach (var a in actvsAcademicas)
                            {
                                <option value="@a["id"]">@ObtenerNombreActv(a)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <input class="form-control" placeholder="Componente" @bind="aaRcComponenteTemp" />
                    </div>
                    <div class="col-md-4">
                        <input class="form-control" placeholder="Semestre" @bind="aaRcSemestreTemp" />
                    </div>
                </div>
                <div class="row mb-2">
                    <div class="col-md-12">
                        <button class="btn btn-outline-primary" @onclick="AgregarAaRc">+ Agregar Actividad</button>
                    </div>
                </div>
                @if (actividadesAgregadas.Any())
                {
                    <table class="table table-sm table-bordered mb-3">
                        <thead class="table-secondary"><tr><th>Actividad</th><th>Componente</th><th>Semestre</th><th>Acciones</th></tr></thead>
                        <tbody>
                            @foreach (var item in actividadesAgregadas)
                            {
                                <tr>
                                    <td>@ObtenerNombreActv(item.actv_academicas_idcurso)</td>
                                    <td>@item.componente</td>
                                    <td>@item.semestre</td>
                                    <td><button class="btn btn-danger btn-sm" @onclick="() => QuitarAaRc(item)">Quitar</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-light border mb-3">No hay actividades académicas agregadas.</div>
                }

                <hr />
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Id</th><th>Programa</th><th>Metodología</th><th>Tipo Titulación</th><th>Fecha Ini</th><th>Fecha Fin</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]</td>
                        <td>@ObtenerNombre(programas, reg["programa"], "id", "nombre")</td>
                        <td>@reg["metodologia"]</td>
                        <td>@reg["tipo_titulacion"]</td>
                        <td>@reg["fecha_ini"]</td>
                        <td>@reg["fecha_fin"]</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en registro_calificado.</div>
    }
</div>

@code {
    private class AaRcTemp
    {
        public int actv_academicas_idcurso { get; set; }
        public string? componente { get; set; }
        public string? semestre { get; set; }
    }

    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> programas = new();
    private List<Dictionary<string, object?>> enfoques = new();
    private List<Dictionary<string, object?>> actvsAcademicas = new();

    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false;
    private string mensaje = string.Empty, campoId = string.Empty;
    private string campoCantPreg = string.Empty, campoCalifPreg = string.Empty, campoHActv = string.Empty;
    private string campoDuracion = string.Empty, campoDocenteSemestres = string.Empty;
    private string campoMetodologia = string.Empty, campoTipoTitulacion = string.Empty;
    private int? campoPrograma = null;
    private DateTime? campoFechaIni = null, campoFechaFin = null;

    private List<int> enfoquesAgregados = new();
    private List<AaRcTemp> actividadesAgregadas = new();
    private int? enfoqueSeleccionado = null, actvSeleccionada = null;
    private string aaRcComponenteTemp = string.Empty, aaRcSemestreTemp = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        programas = await Api.ListarAsync("programa");
        enfoques = await Api.ListarAsync("enfoque");
        actvsAcademicas = await Api.ListarAsync("actv_academica");
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("registro_calificado");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoId = string.Empty; campoCantPreg = string.Empty;
        campoCalifPreg = string.Empty; campoHActv = string.Empty; campoDuracion = string.Empty;
        campoDocenteSemestres = string.Empty; campoMetodologia = string.Empty;
        campoTipoTitulacion = string.Empty; campoPrograma = null; campoFechaIni = null; campoFechaFin = null;
        enfoquesAgregados = new(); actividadesAgregadas = new();
        enfoqueSeleccionado = null; actvSeleccionada = null; aaRcComponenteTemp = string.Empty; aaRcSemestreTemp = string.Empty;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = reg["id"]?.ToString() ?? "";
        campoCantPreg = reg["cant_preg"]?.ToString() ?? "";
        campoCalifPreg = reg["calif_preg"]?.ToString() ?? "";
        campoHActv = reg["h_actv_academica"]?.ToString() ?? "";
        campoDuracion = reg["duracion_anios"]?.ToString() ?? "";
        campoDocenteSemestres = reg["docente_semestres"]?.ToString() ?? "";
        campoMetodologia = reg["metodologia"]?.ToString() ?? "";
        campoTipoTitulacion = reg["tipo_titulacion"]?.ToString() ?? "";
        if (int.TryParse(reg["programa"]?.ToString(), out int p)) campoPrograma = p;
        if (DateTime.TryParse(reg["fecha_ini"]?.ToString(), out DateTime fi)) campoFechaIni = fi;
        if (DateTime.TryParse(reg["fecha_fin"]?.ToString(), out DateTime ff)) campoFechaFin = ff;

        var todosEnfoques = await Api.ListarAsync("enfoque_rc");
        enfoquesAgregados = todosEnfoques
            .Where(x => x["registro_calificado"]?.ToString() == campoId)
            .Select(x => Convert.ToInt32(x["enfoque"]))
            .ToList();

        var todasAaRc = await Api.ListarAsync("aa_rc");
        actividadesAgregadas = todasAaRc
            .Where(x => x["registro_calificado_codigo"]?.ToString() == campoId)
            .Select(x => new AaRcTemp
            {
                actv_academicas_idcurso = Convert.ToInt32(x["actv_academicas_idcurso"]),
                componente = x["componente"]?.ToString(),
                semestre = x["semestre"]?.ToString()
            }).ToList();

        enfoqueSeleccionado = null; actvSeleccionada = null; aaRcComponenteTemp = string.Empty; aaRcSemestreTemp = string.Empty;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void AgregarEnfoque()
    {
        if (enfoqueSeleccionado == null || enfoquesAgregados.Contains(enfoqueSeleccionado.Value)) return;
        enfoquesAgregados.Add(enfoqueSeleccionado.Value);
        enfoqueSeleccionado = null;
    }

    private void QuitarEnfoque(int id) => enfoquesAgregados.Remove(id);

    private void AgregarAaRc()
    {
        if (actvSeleccionada == null || actividadesAgregadas.Any(x => x.actv_academicas_idcurso == actvSeleccionada.Value)) return;
        actividadesAgregadas.Add(new AaRcTemp
        {
            actv_academicas_idcurso = actvSeleccionada.Value,
            componente = aaRcComponenteTemp,
            semestre = aaRcSemestreTemp
        });
        actvSeleccionada = null;
        aaRcComponenteTemp = string.Empty;
        aaRcSemestreTemp = string.Empty;
    }

    private void QuitarAaRc(AaRcTemp item) => actividadesAgregadas.Remove(item);

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["cant_preg"] = campoCantPreg,
            ["calif_preg"] = campoCalifPreg,
            ["h_actv_academica"] = campoHActv,
            ["programa"] = campoPrograma,
            ["fecha_ini"] = campoFechaIni?.ToString("yyyy-MM-dd"),
            ["fecha_fin"] = campoFechaFin?.ToString("yyyy-MM-dd"),
            ["duracion_anios"] = campoDuracion,
            ["docente_semestres"] = campoDocenteSemestres,
            ["metodologia"] = campoMetodologia,
            ["tipo_titulacion"] = campoTipoTitulacion
        };

        (bool exito, string mensaje) resultado = editando
            ? await Api.ActualizarAsync("registro_calificado", "id", campoId, datos)
            : await Api.CrearAsync("registro_calificado", datos);

        if (!resultado.exito)
        {
            exito = false; mensaje = resultado.mensaje; return;
        }

        string rcId = campoId;
        if (!editando)
        {
            var todos = await Api.ListarAsync("registro_calificado");
            rcId = todos.LastOrDefault()?["id"]?.ToString() ?? "";
        }

        if (editando)
        {
            var existentesEnfoques = await Api.ListarAsync("enfoque_rc");
            foreach (var item in existentesEnfoques.Where(x => x["registro_calificado"]?.ToString() == rcId))
                await Api.EliminarAsync("enfoque_rc", item["enfoque"]?.ToString() ?? "", rcId);

            var existentesAaRc = await Api.ListarAsync("aa_rc");
            foreach (var item in existentesAaRc.Where(x => x["registro_calificado_codigo"]?.ToString() == rcId))
                await Api.EliminarAsync("aa_rc", item["actv_academicas_idcurso"]?.ToString() ?? "", rcId);
        }

        foreach (var id in enfoquesAgregados)
            await Api.CrearAsync("enfoque_rc", new Dictionary<string, object?> { ["enfoque"] = id, ["registro_calificado"] = int.Parse(rcId) });

        foreach (var item in actividadesAgregadas)
            await Api.CrearAsync("aa_rc", new Dictionary<string, object?>
            {
                ["actv_academicas_idcurso"] = item.actv_academicas_idcurso,
                ["registro_calificado_codigo"] = int.Parse(rcId),
                ["componente"] = item.componente,
                ["semestre"] = item.semestre
            });

        exito = true;
        mensaje = editando ? "Registro actualizado correctamente" : "Registro creado correctamente";
        mostrarFormulario = false;
        await CargarRegistros();
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        var resultado = await Api.EliminarAsync("registro_calificado", "id", reg["id"]?.ToString() ?? "");
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }

    private string ObtenerNombre(List<Dictionary<string, object?>> lista, object? id, string campoId, string campoNombre)
    {
        if (id == null) return "";
        var item = lista.FirstOrDefault(x => x[campoId]?.ToString() == id.ToString());
        return item?[campoNombre]?.ToString() ?? id.ToString() ?? "";
    }

    private string ObtenerNombreActv(Dictionary<string, object?>? item)
    {
        if (item == null) return "";
        return $"{item["tipo"]} - {item["area_formacion"]}";
    }

    private string ObtenerNombreActv(int id)
    {
        var item = actvsAcademicas.FirstOrDefault(x => x["id"]?.ToString() == id.ToString());
        return ObtenerNombreActv(item);
    }
}
