@page "/alianzas"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="container mt-4">
    <h3>Alianzas</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Alianza</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Alianza" : "Nueva Alianza")</div>
            <div class="card-body">
                <div class="row">
                    @if (editando)
                    {
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Id</label>
                            <input class="form-control" @bind="campoId" disabled />
                        </div>
                    }
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Departamento (ID)</label>
                        <input class="form-control" type="number" @bind="campoDepartamento" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Aliado (ID)</label>
                        <input class="form-control" type="number" @bind="campoAliado" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Docente (ID)</label>
                        <input class="form-control" type="number" @bind="campoDocente" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Inicio</label>
                        <input class="form-control" type="date" @bind="campoFechaIni" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Fin</label>
                        <input class="form-control" type="date" @bind="campoFechaFin" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Id</th><th>Departamento</th><th>Aliado</th><th>Docente</th><th>Fecha Ini</th><th>Fecha Fin</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]</td>
                        <td>@reg["departamento"]</td>
                        <td>@reg["aliado"]</td>
                        <td>@reg["docente"]</td>
                        <td>@reg["fecha_ini"]</td>
                        <td>@reg["fecha_fin"]</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en alianza.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false;
    private string mensaje = string.Empty, campoId = string.Empty;
    private int? campoDepartamento = null, campoAliado = null, campoDocente = null;
    private DateTime? campoFechaIni = null, campoFechaFin = null;

    protected override async Task OnInitializedAsync() => await CargarRegistros();

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("alianza");
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoId = string.Empty;
        campoDepartamento = null; campoAliado = null; campoDocente = null;
        campoFechaIni = null; campoFechaFin = null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = reg["id"]?.ToString() ?? "";
        if (int.TryParse(reg["departamento"]?.ToString(), out int dep)) campoDepartamento = dep;
        if (int.TryParse(reg["aliado"]?.ToString(), out int ali)) campoAliado = ali;
        if (int.TryParse(reg["docente"]?.ToString(), out int doc)) campoDocente = doc;
        if (DateTime.TryParse(reg["fecha_ini"]?.ToString(), out DateTime fi)) campoFechaIni = fi;
        if (DateTime.TryParse(reg["fecha_fin"]?.ToString(), out DateTime ff)) campoFechaFin = ff;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["departamento"] = campoDepartamento, ["aliado"] = campoAliado,
            ["docente"] = campoDocente, ["fecha_ini"] = campoFechaIni, ["fecha_fin"] = campoFechaFin
        };
        var resultado = editando
            ? await Api.ActualizarAsync("alianza", "id", campoId, datos)
            : await Api.CrearAsync("alianza", datos);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        var resultado = await Api.EliminarAsync("alianza", "id", reg["id"]?.ToString() ?? "");
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }
}